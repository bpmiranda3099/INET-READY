-- Create roles as users
CREATE USER 'super_admin'@'localhost';
CREATE USER 'admin'@'localhost';

-- Grant privileges to roles
GRANT ALL PRIVILEGES ON inet_ready_ehr.* TO 'super_admin'@'localhost';

-- Grant additional privileges to admin
GRANT SELECT, INSERT, UPDATE, DELETE ON inet_ready_ehr.Admin TO 'admin'@'localhost';
GRANT SELECT, INSERT, UPDATE, DELETE ON inet_ready_ehr.AdminActivityLog TO 'admin'@'localhost';
GRANT SELECT, INSERT, UPDATE, DELETE ON inet_ready_ehr.AdminFeedback TO 'admin'@'localhost';

-- Assign roles to users
GRANT 'super_admin' TO 'super_admin'@'localhost';
GRANT 'admin' TO 'admin'@'localhost';
